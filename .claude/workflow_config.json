{
  "project_root": "..",
  "roadmap_file": "ROADMAP.md",
  "ledger": {
    "enabled": true,
    "directory": "history"
  },
  "source_directories": ["hooks", "skills", "schemas", "templates"],
  "documentation_directories": ["docs"],
  "env_check": {
    "tool_paths": {
      "python": {
        "path": "python",
        "version_flag": "--version"
      }
    }
  },
  "stop_hook": {
    "max_blocks": 2,
    "main_branch": "main"
  },
  "workflow_update_check": {
    "enabled": false,
    "submodule_path": ".claude/workflow-core",
    "remote": "origin",
    "branch": "main"
  }
}
